{
  "name": "ofetch-action",
  "version": "0.0.0",
  "description": "GitHub Action for HTTP requests powered by unjs/ofetch",
  "license": "MIT",
  "repository": "marr-cloud/ofetch-action",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "obuild",
    "dev": "vitest dev",
    "fmt": "oxlint . --fix && oxfmt .",
    "lint": "oxlint . && oxfmt --check .",
    "test": "pnpm lint && pnpm typecheck && vitest run --coverage",
    "typecheck": "tsgo --noEmit --skipLibCheck"
  },
  "dependencies": {},
  "devDependencies": {
    "@actions/core": "^3.0.1",
    "@types/node": "latest",
    "@typescript/native-preview": "latest",
    "@vitest/coverage-v8": "latest",
    "changelogen": "latest",
    "obuild": "latest",
    "ofetch": "^1.5.1",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "packageManager": "pnpm@10.33.2"
}
